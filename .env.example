# 阿里云 OSS（私有 Bucket，下载使用签名 URL）
OSS_ACCESS_KEY_ID=your_aliyun_access_key_id
OSS_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
OSS_BUCKET_NAME=your_bucket_name
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_URL_EXPIRY_SECONDS=604800

# SMTP（465 SSL）
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your_smtp_password

# Tally Webhook 签名密钥（与表单集成中配置一致）
TALLY_WEBHOOK_SECRET=your_webhook_secret

# 微信公众号「服务器配置」Token（与公众平台一致，用于 GET /wechat/callback 验证）
WECHAT_TOKEN=你设置的token字符串
WECHAT_APPID=你的公众号AppID
WECHAT_APPSECRET=你的公众号AppSecret
H5_BASE_URL=https://example.com

APP_ENV=development
APP_VERSION=1.0.0
